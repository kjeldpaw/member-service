<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.5.xsd">

    <changeSet id="1.0.0" author="junie">
        <createTable tableName="belts">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="wait_time" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="rank" type="INT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="clubs">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints unique="true" nullable="false"/>
            </column>
            <column name="street" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(255)"/>
            <column name="zip_code" type="VARCHAR(255)"/>
        </createTable>

        <createTable tableName="graduations">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="date" type="DATE">
                <constraints nullable="false"/>
            </column>
            <column name="belt_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="graduation_id" type="UUID"/>
        </createTable>

        <createTable tableName="members">
            <column name="id" type="VARCHAR(50)">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="first_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="last_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="street" type="VARCHAR(255)"/>
            <column name="city" type="VARCHAR(255)"/>
            <column name="zip_code" type="VARCHAR(255)"/>
            <column name="phone" type="VARCHAR(255)"/>
            <column name="email" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="date_of_birth" type="DATE"/>
            <column name="club_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="graduation_id" type="UUID"/>
        </createTable>

        <createTable tableName="references">
            <column name="id" type="UUID">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="type" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="reference" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="member_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createTable tableName="members_clubs">
            <column name="member_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="club_id" type="UUID">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="members_clubs" columnNames="member_id, club_id" constraintName="pk_members_clubs"/>

        <createTable tableName="graduation_members">
            <column name="graduation_id" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="member_id" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addPrimaryKey tableName="graduation_members" columnNames="graduation_id, member_id" constraintName="pk_graduation_members"/>

        <addForeignKeyConstraint baseColumnNames="belt_id"
                                 baseTableName="graduations"
                                 constraintName="fk_graduations_belt"
                                 referencedColumnNames="id"
                                 referencedTableName="belts"/>

        <addForeignKeyConstraint baseColumnNames="graduation_id"
                                 baseTableName="graduations"
                                 constraintName="fk_graduations_previous"
                                 referencedColumnNames="id"
                                 referencedTableName="graduations"/>

        <addForeignKeyConstraint baseColumnNames="club_id"
                                 baseTableName="members"
                                 constraintName="fk_members_club"
                                 referencedColumnNames="id"
                                 referencedTableName="clubs"/>

        <addForeignKeyConstraint baseColumnNames="graduation_id"
                                 baseTableName="members"
                                 constraintName="fk_members_graduation"
                                 referencedColumnNames="id"
                                 referencedTableName="graduations"/>

        <addForeignKeyConstraint baseColumnNames="member_id"
                                 baseTableName="references"
                                 constraintName="fk_references_member"
                                 referencedColumnNames="id"
                                 referencedTableName="members"/>

        <addForeignKeyConstraint baseColumnNames="member_id"
                                 baseTableName="members_clubs"
                                 constraintName="fk_members_clubs_member"
                                 referencedColumnNames="id"
                                 referencedTableName="members"/>

        <addForeignKeyConstraint baseColumnNames="club_id"
                                 baseTableName="members_clubs"
                                 constraintName="fk_members_clubs_club"
                                 referencedColumnNames="id"
                                 referencedTableName="clubs"/>

        <addForeignKeyConstraint baseColumnNames="graduation_id"
                                 baseTableName="graduation_members"
                                 constraintName="fk_grad_mem_graduation"
                                 referencedColumnNames="id"
                                 referencedTableName="graduations"/>

        <addForeignKeyConstraint baseColumnNames="member_id"
                                 baseTableName="graduation_members"
                                 constraintName="fk_grad_mem_member"
                                 referencedColumnNames="id"
                                 referencedTableName="members"/>
    </changeSet>

</databaseChangeLog>
